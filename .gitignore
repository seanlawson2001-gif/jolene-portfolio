# .gitignore
# These files will NOT be uploaded to GitHub.

# Environment files — NEVER commit these (they contain secret keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js build output
.next/
out/

# Node modules
node_modules/

# OS files
.DS_Store
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel
