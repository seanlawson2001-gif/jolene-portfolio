# .env.example
# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES — TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════
#
# IMPORTANT: Do NOT paste real credentials here.
# This file is a safe template that gets committed to GitHub.
#
# HOW TO USE THIS FILE:
# 1. Copy this file and rename the copy to: .env.local
# 2. Fill in the real values in .env.local
# 3. .env.local is in .gitignore — it will NEVER be uploaded to GitHub
#
# See README.md → "Setting Up Google Sheets" for the full setup guide.
# ═══════════════════════════════════════════════════════════════════════════

# ─── GOOGLE SHEETS INTEGRATION ────────────────────────────────────────────
#
# These three variables connect the contact form to a Google Sheet.
# You get them from a Google Cloud service account.
# See lib/googleSheets.ts and README.md for detailed setup instructions.

# The service account email — looks like: name@project-id.iam.gserviceaccount.com
GOOGLE_SHEETS_CLIENT_EMAIL=

# The service account private key — starts with: -----BEGIN RSA PRIVATE KEY-----
# IMPORTANT: Paste the FULL key including the -----BEGIN----- and -----END----- lines.
# In .env.local, the newlines inside the key become literal \n characters.
GOOGLE_SHEETS_PRIVATE_KEY=

# The ID from your Google Sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# ─── OPTIONAL ─────────────────────────────────────────────────────────────
# If you want to add other services in future (e.g. email notifications via Resend)
# add their environment variables here.
# RESEND_API_KEY=
